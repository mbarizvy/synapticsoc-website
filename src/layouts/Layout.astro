---
import '../styles/global.css';

const {
  title = 'SynapticSOC — Open-Source Security Operations Center',
  description = 'SynapticSOC is an independently built open-source SOC project using real hardware, real telemetry, and practical engineering decisions.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/assets/logos/synapticsoc-symbol.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>