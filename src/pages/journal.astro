---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('journal', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const sortedEntries = entries.sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<Layout
  title="Build Journal — SynapticSOC"
  description="Follow the SynapticSOC build journal: architecture decisions, implementation notes, visibility improvements, triage workflow, evidence handling, and open-source SOC lessons."
>
  <header class="site-header">
    <div class="container navbar">
      <a class="brand" href="/" aria-label="SynapticSOC home">
        <img src="/assets/logos/synapticsoc-symbol.svg" alt="" />
        <span>Synaptic<span class="brand-soc">SOC</span></span>
      </a>

      <nav class="nav-links" aria-label="Primary navigation">
        <a href="/project">The Project</a>
        <a href="/architecture">Architecture</a>
        <a href="/journal" aria-current="page">Build Journal</a>
        <a href="/#about">About</a>
      </nav>

      <a
        class="nav-github"
        href="https://github.com/mbarizvy/synapticsoc-website"
        target="_blank"
        rel="noreferrer"
      >
        GitHub
      </a>
    </div>
  </header>

  <main class="journal-page">
    <section class="journal-hero">
      <div class="container">
        <p class="eyebrow">Build Journal</p>

        <h1>
          Engineering notes from a practical
          <span>open-source SOC build</span>
        </h1>

        <p>
          A public record of SynapticSOC architecture decisions, implementation
          progress, integration problems, visibility improvements, and lessons
          learned while building a real open-source SOC workflow.
        </p>
      </div>
    </section>

    <section class="journal-list-section">
      <div class="container">
        <div class="journal-list-heading">
          <p class="section-kicker">Latest entries</p>
          <h2>Documenting the build as it evolves</h2>
        </div>

        <div class="journal-grid">
          {sortedEntries.map((entry) => (
            <article class="journal-card">
              <div class="journal-card-meta">
                <span>{entry.data.category}</span>
                <time datetime={entry.data.date.toISOString()}>
                  {formatDate(entry.data.date)}
                </time>
              </div>

              <h3>
                <a href={`/journal/${entry.id}`}>
                  {entry.data.title}
                </a>
              </h3>

              <p>{entry.data.summary}</p>

              <div class="journal-tags">
                {entry.data.tags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>

              <a class="journal-read-link" href={`/journal/${entry.id}`}>
                Read entry →
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-row">
      <span>© 2026 SynapticSOC</span>

      <div class="footer-links">
        <a href="/">Home</a>
        <a href="/architecture">Architecture</a>
        <a href="/journal">Build Journal</a>
        <a href="https://github.com/mbarizvy" target="_blank" rel="noreferrer">
          GitHub
        </a>
      </div>
    </div>
  </footer>

  <style>
    .journal-page {
      overflow: hidden;
    }

    .journal-hero {
      padding: 104px 0 78px;
      background:
        radial-gradient(circle at 18% 18%, rgba(35, 217, 217, 0.08), transparent 30%),
        radial-gradient(circle at 82% 26%, rgba(126, 16, 194, 0.10), transparent 32%);
    }

    .journal-hero h1 {
      max-width: 900px;
      margin: 0;
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(3rem, 7vw, 5.8rem);
      line-height: 0.98;
      letter-spacing: -0.075em;
    }

    .journal-hero h1 span {
      display: block;
      background: linear-gradient(135deg, var(--cyan), #7e8cff 52%, var(--violet));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    .journal-hero > .container > p:not(.eyebrow) {
      max-width: 760px;
      margin: 28px 0 0;
      color: var(--text-secondary);
      font-size: 1.08rem;
    }

    .journal-list-section {
      padding: 92px 0;
      border-top: 1px solid rgba(27, 39, 64, 0.7);
    }

    .journal-list-heading {
      max-width: 780px;
      margin-bottom: 42px;
    }

    .journal-list-heading h2 {
      margin: 0;
      font-family: 'Space Grotesk', sans-serif;
      font-size: clamp(2.2rem, 5vw, 4rem);
      line-height: 1.04;
      letter-spacing: -0.06em;
    }

    .journal-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
    }

    .journal-card {
      display: flex;
      flex-direction: column;
      min-height: 360px;
      padding: 28px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: linear-gradient(180deg, rgba(18, 26, 43, 0.96), rgba(13, 18, 32, 0.96));
      box-shadow: 0 18px 46px rgba(0, 0, 0, 0.18);
    }

    .journal-card-meta {
      display: flex;
      justify-content: space-between;
      gap: 16px;
      color: var(--text-muted);
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    .journal-card h3 {
      margin: 24px 0 0;
      font-family: 'Space Grotesk', sans-serif;
      font-size: 1.45rem;
      line-height: 1.12;
      letter-spacing: -0.04em;
    }

    .journal-card h3 a {
      color: var(--text-primary);
      text-decoration: none;
    }

    .journal-card h3 a:hover {
      color: var(--cyan);
    }

    .journal-card p {
      margin: 16px 0 0;
      color: var(--text-secondary);
    }

    .journal-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 22px;
    }

    .journal-tags span {
      padding: 6px 9px;
      border-radius: 999px;
      border: 1px solid rgba(35, 217, 217, 0.22);
      color: var(--cyan);
      font-size: 0.72rem;
      background: rgba(35, 217, 217, 0.06);
    }

    .journal-read-link {
      margin-top: auto;
      padding-top: 28px;
      color: var(--cyan);
      font-weight: 700;
      text-decoration: none;
    }

    @media (max-width: 980px) {
      .journal-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 700px) {
      .journal-hero {
        padding: 68px 0 58px;
      }

      .journal-hero h1 {
        font-size: clamp(2.55rem, 14vw, 4rem);
      }

      .journal-list-section {
        padding: 68px 0;
      }

      .journal-grid {
        grid-template-columns: 1fr;
      }

      .journal-card {
        min-height: auto;
        padding: 22px;
      }

      .journal-card-meta {
        flex-direction: column;
        gap: 6px;
      }
    }
  </style>
</Layout>
